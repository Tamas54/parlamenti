# Parlamentaris Kompendium MCP — környezeti változók
#
# Railway-en ezek környezeti változókként állíthatók be.
# Lokálisan: cp .env.example .env

# Szerver
HOST=0.0.0.0
PORT=8000

# Embedding modell (Sprint 3-ban aktiválódik)
# Alapértelmezett: multilingual MiniLM (kicsi, gyors, jó magyar)
# EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Logging szint
LOG_LEVEL=INFO
